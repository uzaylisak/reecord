# ─── REEcord Environment Variables ───────────────────────────────────────────
# Copy this file to .env and fill in your values.
# WARNING: Never commit .env to git!

# Gensyn testnet wallet private key (starts with 0x or 64-char hex)
GENSYN_PRIVATE_KEY=your_private_key_here

# Wallet address (starts with 0x)
GENSYN_WALLET_ADDRESS=0x...

# Gensyn Testnet RPC (no need to change)
GENSYN_RPC_URL=https://gensyn-testnet.g.alchemy.com/public

# Pinata JWT token for IPFS upload (https://app.pinata.cloud/developers/api-keys)
# Optional — without this, receipts use a local hash fallback
PINATA_API_KEY=your_pinata_jwt_here

# REE model (no need to change)
REE_MODEL=Qwen/Qwen2-0.5B

# REE max tokens
REE_MAX_TOKENS=50
